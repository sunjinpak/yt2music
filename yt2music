#!/bin/zsh
# yt2music — YouTube URL을 MP3로 추출하여 Music 앱에 추가하고 가사를 임베드한다.
# Usage:
#   yt2music <youtube_url>
#   yt2music <youtube_url> <playlist_name>   # 예: yt2music URL CCM

set -e

URL="${1:-}"
PLAYLIST="${2:-}"
if [[ -z "$URL" ]]; then
  echo "Usage: yt2music <youtube_url> [playlist_name]"
  exit 1
fi

WORKDIR="$HOME/Downloads/yt-audio"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

echo "[1/4] 메타데이터 확인 중..."
META=$(yt-dlp --print "%(title)s|%(language)s|%(artist|)s|%(track|)s|%(album|)s|%(release_year|)s|%(uploader)s" "$URL" 2>/dev/null)
TITLE=$(echo "$META" | awk -F'|' '{print $1}')
LANG=$(echo "$META"  | awk -F'|' '{print $2}')
YT_ARTIST=$(echo "$META"   | awk -F'|' '{print $3}')
YT_TRACK=$(echo "$META"    | awk -F'|' '{print $4}')
YT_ALBUM=$(echo "$META"    | awk -F'|' '{print $5}')
YT_YEAR=$(echo "$META"     | awk -F'|' '{print $6}')
YT_UPLOADER=$(echo "$META" | awk -F'|' '{print $7}')
if [[ -z "$TITLE" ]]; then
  echo "❌ 영상 정보를 가져올 수 없습니다."
  exit 1
fi
echo "      → $TITLE (lang=$LANG)"

# 공식 제목/아티스트 정규화 (yt-dlp 메타 우선, 없으면 제목 휴리스틱)
CLEAN_OUT=$(python3 - "$TITLE" "$YT_ARTIST" "$YT_TRACK" "$YT_UPLOADER" <<'PYEOF'
import re, sys
title, yt_artist, yt_track, yt_uploader = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]

SUFFIX_PATTERNS = [
    r"\bofficial\s+music\s+video\b", r"\bofficial\s+video\b", r"\bofficial\s+audio\b",
    r"\bmusic\s+video\b", r"\blyric\s+video\b", r"\blyrics\s+video\b",
    r"\bofficial\b", r"\baudio\b", r"\blyrics?\b",
    r"\bvisualizer\b", r"\bmv\b", r"\bm/v\b", r"\bhd\b", r"\bhq\b", r"\b4k\b",
    r"\bremaster(ed)?\b", r"\bfeat\.?\s+[^()\[\]]+",
]
SUFFIX_RE = re.compile("|".join(SUFFIX_PATTERNS), re.IGNORECASE)

def clean(t: str) -> str:
    t = t.strip()
    for _ in range(4):
        new = re.sub(r"[\(\[\{][^()\[\]{}]*[\)\]\}]\s*$", lambda m: m.group(0) if not SUFFIX_RE.search(m.group(0)) else "", t).strip()
        if new == t: break
        t = new
    t = re.sub(r"\s*[\|\-–—:]\s*(" + "|".join(SUFFIX_PATTERNS) + r")\s*$", "", t, flags=re.IGNORECASE).strip()
    for _ in range(3):
        new = re.sub(r"\s+(" + "|".join(SUFFIX_PATTERNS) + r")\s*$", "", t, flags=re.IGNORECASE).strip()
        if new == t: break
        t = new
    t = re.sub(r"\s{2,}", " ", t).strip(" -–—|:")
    return t

clean_title = clean(title)

if yt_artist and yt_track:
    artist, track = yt_artist.strip(), yt_track.strip()
else:
    parts = re.split(r"\s+[\-–—|]\s+", clean_title, maxsplit=1)
    if len(parts) == 2 and 1 <= len(parts[0]) <= 60:
        artist, track = parts[0].strip(), parts[1].strip()
    else:
        artist, track = (yt_uploader or "").strip(), clean_title

print(track)
print(artist)
PYEOF
)
CLEAN_TITLE=$(echo "$CLEAN_OUT" | sed -n '1p')
CLEAN_ARTIST=$(echo "$CLEAN_OUT" | sed -n '2p')
echo "      → 정규화: $CLEAN_ARTIST — $CLEAN_TITLE"

# 영상 언어에 따라 자막 우선순위 결정
if [[ "$LANG" == "ko" ]]; then
  SUB_LANGS="ko,en"
  SUB_ORDER=(ko en)
else
  SUB_LANGS="en,ko"
  SUB_ORDER=(en ko)
fi

echo "[2/4] MP3 추출 + 썸네일/메타데이터 임베드..."
BEFORE_TS=$(date +%s)
yt-dlp -x --audio-format mp3 --audio-quality 0 \
  --embed-thumbnail --embed-metadata \
  -o "%(title)s.%(ext)s" \
  "$URL" > /tmp/yt2music.log 2>&1 || {
    echo "❌ 다운로드 실패. 로그: /tmp/yt2music.log"
    exit 1
  }

# 방금 생성된 가장 최근 MP3를 매칭 (yt-dlp가 sanitize한 파일명 대응)
MP3_PATH=$(find "$WORKDIR" -maxdepth 1 -name "*.mp3" -newermt "@$BEFORE_TS" 2>/dev/null | head -1)
[[ -z "$MP3_PATH" ]] && MP3_PATH=$(ls -t "$WORKDIR"/*.mp3 2>/dev/null | head -1)
echo "      → $(basename "$MP3_PATH")"

# 자막은 별도 호출 (실패해도 진행)
VTT_PATH=""
yt-dlp --skip-download --write-sub --write-auto-sub \
  --sub-lang "$SUB_LANGS" --sub-format vtt \
  -o "${MP3_PATH%.mp3}.%(ext)s" \
  "$URL" >> /tmp/yt2music.log 2>&1 || true
for lang in "${SUB_ORDER[@]}"; do
  candidate="${MP3_PATH%.mp3}.${lang}.vtt"
  if [[ -f "$candidate" ]]; then
    VTT_PATH="$candidate"
    echo "      → 자막: $lang"
    break
  fi
done

echo "[3/4] 가사 추출 (자막 → 평문)..."
LYRICS_FILE=""
if [[ -n "$VTT_PATH" && -f "$VTT_PATH" ]]; then
  LYRICS_FILE="/tmp/yt2music_lyrics.txt"
  python3 - "$VTT_PATH" <<'PYEOF' > "$LYRICS_FILE"
import re, sys
seen = []
with open(sys.argv[1], encoding="utf-8") as f:
    for line in f:
        line = line.rstrip()
        if not line or line.startswith(("WEBVTT", "Kind:", "Language:")):
            continue
        if "-->" in line or re.match(r"^\d+$", line):
            continue
        clean = re.sub(r"<[^>]+>", "", line).strip()
        if not clean:
            continue
        if seen and seen[-1] == clean:
            continue
        seen.append(clean)
print("\n".join(seen))
PYEOF
  CHARS=$(wc -c < "$LYRICS_FILE" | tr -d ' ')
  if [[ "$CHARS" -eq 0 ]]; then
    LYRICS_FILE=""
    echo "      → 가사 비어있음 (스킵)"
  else
    echo "      → ${CHARS} 글자 추출됨"
  fi
else
  echo "      → 자막 없음 (가사 스킵)"
fi

echo "[4/4] Music 앱에 추가 + 메타데이터/가사 임베드..."
# 한글 안전하게 character 단위로 자른 매칭용 prefix (raw YouTube title 기준)
SHORT_TITLE=$(python3 -c 'import sys; t=sys.argv[1]; print(t[:20].replace("\"","\\\""))' "$TITLE")

osascript <<APPLESCRIPT > /dev/null
tell application "Music"
  set newTracks to (open POSIX file "$MP3_PATH")
end tell
APPLESCRIPT

sleep 2

if [[ -n "$LYRICS_FILE" ]]; then
  LYRICS_ARG="$LYRICS_FILE"
else
  LYRICS_ARG=""
fi

osascript <<APPLESCRIPT
set lyricsPath to "$LYRICS_ARG"
set targetPlaylist to "$PLAYLIST"
set cleanName to "$CLEAN_TITLE"
set cleanArtist to "$CLEAN_ARTIST"
set cleanAlbum to "$YT_ALBUM"
set cleanYearStr to "$YT_YEAR"
tell application "Music"
  set foundTracks to (every track of library playlist 1 whose name contains "$SHORT_TITLE")
  if (count of foundTracks) > 0 then
    set t to item 1 of foundTracks
    if cleanName is not "" then set name of t to cleanName
    if cleanArtist is not "" then set artist of t to cleanArtist
    if cleanAlbum is not "" then set album of t to cleanAlbum
    if cleanYearStr is not "" then
      try
        set year of t to (cleanYearStr as integer)
      end try
    end if
    if lyricsPath is not "" then
      set lyricsText to (read POSIX file lyricsPath as «class utf8»)
      set lyrics of t to lyricsText
    end if
    if targetPlaylist is not "" then
      try
        duplicate t to playlist targetPlaylist
      on error errMsg
        return "WARN: playlist '" & targetPlaylist & "' not found (" & errMsg & ")"
      end try
      return "OK: " & (name of t) & " → " & targetPlaylist
    else
      return "OK: " & (name of t)
    end if
  else
    return "ADDED (트랙 매칭 실패)"
  end if
end tell
APPLESCRIPT

echo ""
echo "✅ 완료: Music 앱 라이브러리에서 확인하세요."
